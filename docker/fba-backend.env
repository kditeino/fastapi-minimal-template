# ============================================================================
# FastAPI backend env for the docker-compose stack.
# Mounted read-only into fba-backend container as /fba/backend/.env
# ============================================================================

# Env
ENVIRONMENT='dev'

# CORS — the frontend is served at / on the same origin as the API proxy, but
# these extra entries let you hit the backend directly from the host during
# development (e.g. Swagger at http://localhost:8001/docs).
CORS_ALLOWED_ORIGINS=["http://localhost","http://localhost:8080","http://127.0.0.1:8080","http://localhost:8001","http://127.0.0.1:8001"]

# Database — talks to the fba-mysql container over the compose network.
DATABASE_TYPE='mysql'
DATABASE_HOST='fba-mysql'
DATABASE_PORT=3306
DATABASE_USER='root'
DATABASE_PASSWORD='fba_root_pwd'
DATABASE_SCHEMA='fba'

# Redis — fba-redis container
REDIS_HOST='fba-redis'
REDIS_PORT=6379
REDIS_PASSWORD=''
REDIS_DATABASE=0

# Token — IMPORTANT: change this in production
TOKEN_SECRET_KEY='1VkVF75nsNABBjK_7-qz7GtzNy3AMvktc9TCPwKczCk'

# Celery — not enabled in the minimal compose stack. Task pages will show
# "unavailable" until you add a celery worker + rabbitmq service.
CELERY_BROKER_REDIS_DATABASE=1
CELERY_RABBITMQ_HOST='fba-rabbitmq'
CELERY_RABBITMQ_PORT=5672
CELERY_RABBITMQ_USERNAME='guest'
CELERY_RABBITMQ_PASSWORD='guest'

# Plugins
OAUTH2_GITHUB_CLIENT_ID=''
OAUTH2_GITHUB_CLIENT_SECRET=''
OAUTH2_GOOGLE_CLIENT_ID=''
OAUTH2_GOOGLE_CLIENT_SECRET=''
EMAIL_USERNAME=''
EMAIL_PASSWORD=''
