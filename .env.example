# ============================================================================
# docker-compose.yml configuration
# Copy this file to `.env` and adjust as needed:
#     cp .env.example .env
# ============================================================================

# Host ports (change if something is already listening on these)
FRONTEND_PORT=8080
BACKEND_PORT=8001
MYSQL_PORT=3306
REDIS_PORT=6379

# MySQL
MYSQL_ROOT_PASSWORD=fba_root_pwd
MYSQL_DATABASE=fba

# ⚠️  If you change MYSQL_ROOT_PASSWORD / MYSQL_DATABASE above, you must
# update docker/fba-backend.env to match — the backend reads from that file.
