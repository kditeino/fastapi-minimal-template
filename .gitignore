# General logs
*.log

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
.temp/

# Node modules (if using Node.js projects)
node_modules/

# Python cache (if using Python projects)
__pycache__/
*.pyc

# Rust build (if using Rust projects)
target/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Local tooling state
.omc/
.claude/

# Python virtualenvs
.venv/
venv/

# Local env files (contain secrets — ship .env.example instead)
api/backend/.env
web/.env.local
.deploy/
